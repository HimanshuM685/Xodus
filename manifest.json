{
  "manifest_version": 3,
  "name": "Xodus — X Bookmark Exporter",
  "version": "0.1.0",
  "description": "Export your X (Twitter) bookmarks to CSV, Markdown, or Notion. Local-only, bring-your-own-token, zero telemetry.",
  "permissions": ["storage", "unlimitedStorage", "tabs"],
  "host_permissions": [
    "https://x.com/*",
    "https://twitter.com/*",
    "https://api.notion.com/*"
  ],
  "background": {
    "service_worker": "src/background/service-worker.js",
    "type": "module"
  },
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_title": "Xodus — Export X bookmarks"
  },
  "options_page": "src/options/options.html",
  "content_scripts": [
    {
      "matches": ["https://x.com/*", "https://twitter.com/*"],
      "js": ["src/content/interceptor.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["https://x.com/*", "https://twitter.com/*"],
      "js": ["src/content/xparser.js", "src/content/bridge.js"],
      "run_at": "document_start",
      "world": "ISOLATED"
    }
  ]
}
